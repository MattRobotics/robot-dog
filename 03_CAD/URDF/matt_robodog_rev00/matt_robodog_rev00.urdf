<!-- MATDOG MESH UNIT CONVENTION | STL vertex coordinates are exported from CAD in millimetres. Every visual and collision mesh applies scale="0.001 0.001 0.001" so the URDF remains SI-consistent: joint origins and CoM are metres; mass is kg; inertia is kg·m². -->
<robot name="matt_robodog_rev00">
  <!-- MATDOG DYNAMIC PROPERTIES REV00 | 17-link CAD baseline mass: 2.480 kg | Per-link standard URDF <inertial> blocks are populated from Solid Edge physical-property reports. CoM origins are expressed in each local link frame; inertia tensors are about those CoMs and expressed in link axes. Detailed provenance, symmetry derivation and aggregate validation are recorded in Coordinate_Cinematiche_matt_robodog_rev00.xlsx / Inertial_Properties. No standalone neck yaw actuator link is represented in REV00. -->
  <link name="base_link">
    <!-- MATDOG_DYNAMIC_PROPERTIES | mass_kg=1.282000 | coM_frame=local_link | tensor_frame=local_link_at_com | method=CAD direct: principal axes + radii of gyration | symmetry=direct CAD export | source=physprop__base_link.txt + weight_breakdown_summary.txt -->
