      <origin xyz="0.00584 -0.00065 0.02773" rpy="0 0 0" />
      <mass value="1.282000" />
      <inertia ixx="0.00147265728657" ixy="1.42294028465e-05" ixz="-0.000443609672652" iyy="0.00887012995059" iyz="-7.70141299896e-06" izz="0.00949906085204" />
